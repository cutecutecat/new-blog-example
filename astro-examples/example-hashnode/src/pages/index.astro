---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getAuthor } from '../data/authors';
import { estimateReadingTime, formatReadTime } from '../utils/readingTime';

const posts = (await getCollection('blog')).sort((a, b) => {
	if (a.data.pinned !== b.data.pinned) {
		return Number(b.data.pinned) - Number(a.data.pinned);
	}
	return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const postGroups = [
	{ key: 'all', label: 'All' },
	{ key: 'labs', label: 'Labs' },
	{ key: 'release', label: 'Release' },
] as const;

type PostGroup = (typeof postGroups)[number]['key'];
const defaultGroup: PostGroup = 'all';
const getGroupFromId = (id: string): PostGroup => {
	const rootDir = id.split('/')[0]?.toLowerCase();
	return rootDir === 'release' ? 'release' : 'labs';
};

const postsWithReadTime = posts.map((post) => ({
	post,
	readTime: estimateReadingTime(post.body).minutes,
	author: getAuthor(post.data.author),
	group: getGroupFromId(post.id),
}));

const groupCount = postGroups.reduce<Record<PostGroup, number>>(
	(acc, group) => {
		acc[group.key] = group.key === 'all'
			? postsWithReadTime.length
			: postsWithReadTime.filter((item) => item.group === group.key).length;
		return acc;
	},
	{ all: 0, labs: 0, release: 0 },
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.blog-main {
				max-width: 1120px;
				padding-top: 2.2rem;
			}
			.blog-intro {
				max-width: 1120px;
				margin-bottom: 2.4rem;
				padding: 1.95rem 1.5rem 1.7rem;
				border: 1px solid var(--line);
				border-radius: 18px;
				background: color-mix(in srgb, var(--surface) 96%, #eef2f6);
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
			}
			.blog-intro p {
				margin: 0;
			}
			.brand-avatar {
				width: 78px;
				height: 78px;
				border-radius: 999px;
				background: #243b6b;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 0.95rem;
			}
			.blog-intro h1 {
				margin: 0;
				font-size: clamp(1.55rem, 3.4vw, 2.08rem);
				letter-spacing: -0.015em;
				line-height: 1.2;
			}
			.blog-intro .sub {
				margin-top: 0.38rem;
				color: color-mix(in srgb, var(--muted) 84%, var(--text));
				font-size: clamp(1rem, 2.25vw, 1.25rem);
			}
			.blog-intro .summary {
				margin-top: 1rem;
				max-width: 680px;
				color: var(--muted);
				font-size: clamp(1rem, 1.8vw, 1.16rem);
				line-height: 1.52;
			}
			.blog-intro .links {
				margin-top: 1rem;
				font-size: 0.95rem;
				color: var(--muted);
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.65rem;
				flex-wrap: wrap;
			}
			.blog-intro .links a {
				color: inherit;
				text-decoration: none;
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 1.8rem;
				height: 1.8rem;
				border-radius: 8px;
				border: 1px solid transparent;
				transition: border-color 140ms ease, color 140ms ease, background-color 140ms ease;
			}
			.blog-intro .links a:hover {
				color: var(--accent);
				border-color: var(--line-strong);
				background: var(--surface);
			}
			.blog-intro .links svg {
				width: 1.08rem;
				height: 1.08rem;
			}
			.group-tabs {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				border-bottom: none;
				padding-bottom: 0.1rem;
				margin-bottom: 1.35rem;
				overflow-x: auto;
				scrollbar-width: none;
			}
			.group-tabs::-webkit-scrollbar {
				display: none;
			}
			.group-tab {
				appearance: none;
				border: 1px solid var(--line);
				background: color-mix(in srgb, var(--surface) 94%, #edf1f7);
				margin: 0;
				padding: 0.38rem 0.78rem;
				font: inherit;
				color: var(--muted);
				font-size: 0.88rem;
				font-weight: 600;
				line-height: 1.1;
				white-space: nowrap;
				border-radius: 999px;
				cursor: pointer;
				transition: color 140ms ease, background-color 140ms ease, border-color 140ms ease;
			}
			.group-tab[aria-pressed='true'] {
				color: var(--text);
				font-weight: 600;
				background: var(--surface);
				border-color: var(--line-strong);
			}
			.group-tab:hover {
				color: var(--text);
				border-color: var(--line-strong);
			}
			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: 1fr;
				gap: 1rem;
			}
			.post-item,
			.post-item.is-featured {
				grid-column: 1;
			}
			.post-link {
				display: block;
				height: 100%;
				padding: 1.6rem 1.7rem;
				border-radius: 18px;
				border: 1px solid var(--line);
				background: color-mix(in srgb, var(--surface) 96%, #f0f3f8);
				text-decoration: none;
				box-shadow: none;
				transition: border-color 140ms ease, background-color 140ms ease;
			}
			.post-link:hover {
				border-color: var(--line-strong);
				background: var(--surface);
			}
			.post-link.has-image {
				display: flex;
				flex-direction: row-reverse;
				align-items: stretch;
				gap: 1.2rem;
			}
			.post-link > img {
				display: none;
				width: clamp(260px, 35%, 410px);
				flex-shrink: 0;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 12px;
				border: 1px solid var(--line);
			}
			.post-link.has-image > img {
				display: block;
			}
			.post-content {
				padding: 0;
			}
			.title {
				margin: 0.35rem 0 0.8rem;
				color: var(--text);
				line-height: 1.23;
				letter-spacing: -0.02em;
				font-size: clamp(1.08rem, 1.78vw, 1.42rem);
			}
			.desc {
				margin: 0 0 0.95rem;
				color: var(--muted);
				font-size: clamp(0.9rem, 1.06vw, 1.02rem);
				line-height: 1.48;
			}
			.date {
				margin: 0;
				color: var(--muted);
				font-size: clamp(0.88rem, 0.9vw, 0.98rem);
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.45rem;
			}
			.author {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				color: inherit;
			}
			.author-avatar {
				display: none;
			}
			.pinned {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				margin: 0 0 0.35rem;
				padding: 0.24rem 0.65rem;
				border-radius: 999px;
				border: 1px solid #d8dee8;
				color: #28303d;
				background: #edf1f5;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				width: fit-content;
			}
			.readmore {
				display: none;
			}
			.empty-group {
				margin: 0;
				padding: 1rem 0.4rem;
				color: var(--muted);
				font-size: 0.95rem;
			}
			.load-more-wrap {
				margin-top: 1rem;
				display: flex;
				justify-content: center;
			}
			.load-more-button {
				appearance: none;
				border: 1px solid var(--line);
				background: var(--surface);
				color: var(--accent);
				font: inherit;
				font-size: 0.92rem;
				font-weight: 600;
				padding: 0.6rem 1rem;
				border-radius: 999px;
				cursor: pointer;
				transition: border-color 140ms ease, transform 140ms ease, background-color 140ms ease;
			}
			.load-more-button:hover {
				border-color: color-mix(in srgb, var(--accent) 40%, var(--line));
				background: var(--accent-soft);
				transform: translateY(-1px);
			}
			@media (max-width: 720px) {
				.post-link {
					padding: 1.12rem 1.04rem;
					border-radius: 14px;
				}
				.post-link.has-image {
					flex-direction: column;
					gap: 0.75rem;
				}
				.post-link.has-image > img {
					width: 100%;
				}
				.blog-main {
					padding-top: 1.8rem;
				}
				.group-tabs {
					gap: 0.55rem;
				}
				.group-tab {
					font-size: 0.82rem;
				}
				.blog-intro {
					border-radius: 14px;
					padding: 1.32rem 1rem 1.15rem;
				}
				.brand-avatar {
					width: 68px;
					height: 68px;
					margin-bottom: 0.8rem;
				}
				.blog-intro h1 {
					font-size: 1.36rem;
				}
				.blog-intro .sub {
					font-size: 1rem;
				}
				.blog-intro .summary {
					margin-top: 0.72rem;
					font-size: 0.98rem;
				}
				.title {
					font-size: clamp(1.08rem, 6vw, 1.28rem);
				}
				.desc {
					font-size: 0.94rem;
					line-height: 1.45;
				}
				.date {
					font-size: 0.86rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
			<main class="blog-main">
				<section class="blog-intro">
					<div class="brand-avatar" aria-hidden="true">
						<svg viewBox="0 0 28 28" width="32" height="32">
							<defs>
								<linearGradient id="shieldCoreA" x1="5.6" y1="5.2" x2="22.4" y2="24.8" gradientUnits="userSpaceOnUse">
									<stop offset="0" stop-color="#78f0ff" />
									<stop offset="1" stop-color="#4567ff" />
								</linearGradient>
								<linearGradient id="bladeA" x1="14" y1="5.8" x2="14" y2="19.2" gradientUnits="userSpaceOnUse">
									<stop offset="0" stop-color="#f4fbff" />
									<stop offset="1" stop-color="#9ed7ff" />
								</linearGradient>
							</defs>
							<path
								d="M14 3.2 22.3 6.9v7.4c0 5.2-3.2 9.1-8.3 11.3-5.1-2.2-8.3-6.1-8.3-11.3V6.9z"
								fill="url(#shieldCoreA)"
								stroke="#d4f8ff"
								stroke-width="0.8"
							/>
							<path d="M14 5.8 16.1 10.8 14 19.2 11.9 10.8z" fill="url(#bladeA)" stroke="#d9f6ff" stroke-width="0.6" />
							<path d="M10.9 11.2h6.2" stroke="#d5f7ff" stroke-width="0.9" stroke-linecap="round" />
							<path d="M14 19.2v3.1" stroke="#9ad9ff" stroke-width="0.85" stroke-linecap="round" />
							<path d="M12.6 22.3h2.8" stroke="#9ad9ff" stroke-width="0.85" stroke-linecap="round" />
							<path d="M9 9.3 6.8 11.2m12.2-1.9 2.2 1.9M8.6 14.5l-1.8 1.6m12.4-1.6 1.8 1.6" stroke="#9af3ff" stroke-width="0.75" stroke-linecap="round" opacity="0.9" />
							<circle cx="14" cy="11.2" r="0.9" fill="#e9fdff" />
						</svg>
					</div>
				<h1>WatchU | Agent Security</h1>
				<p class="sub" data-current-post-count>{groupCount.all} posts</p>
				<p class="summary">Protect autonomous agents with real-time monitoring, risk detection, and policy guardrails.</p>
				<p class="links" aria-label="Social links">
					<a href="#" aria-label="WatchU on X">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M18.9 2H22l-6.8 7.7L23.2 22h-6.3l-5-6.5L6.2 22H3l7.3-8.3L.8 2h6.5l4.5 6 7.1-6zM17.8 20h1.7L6.4 3.9H4.6L17.8 20z"
							></path>
						</svg>
					</a>
					<a href="#" aria-label="WatchU on GitHub">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12 2C6.5 2 2 6.6 2 12.2c0 4.5 2.9 8.4 6.9 9.8.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.3-1.1-1.6-1.1-1.6-.9-.6.1-.6.1-.6 1 .1 1.6 1 1.6 1 .9 1.6 2.4 1.1 3 .8.1-.7.4-1.1.6-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2.1 1-2.8-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.9 1.1a9.4 9.4 0 015.2 0c2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.4.1 2.7.7.8 1 1.7 1 2.8 0 3.9-2.4 4.8-4.7 5 .4.3.7 1 .7 2v3c0 .3.2.6.7.5 4-1.4 6.9-5.3 6.9-9.8C22 6.6 17.5 2 12 2z"
							></path>
						</svg>
					</a>
					<a href="#" aria-label="WatchU on LinkedIn">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M5.4 8.5a1.8 1.8 0 110-3.6 1.8 1.8 0 010 3.6zM3.8 9.9h3.1V20H3.8V9.9zm5 0h3v1.4h.1c.4-.8 1.5-1.6 3-1.6 3.2 0 3.8 2.1 3.8 4.8V20h-3.1v-4.9c0-1.2 0-2.7-1.7-2.7s-1.9 1.3-1.9 2.6V20H8.8V9.9z"
							></path>
						</svg>
					</a>
					<a href="#" aria-label="WatchU website">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path
								fill="currentColor"
								d="M12 2a10 10 0 100 20 10 10 0 000-20zm7.9 9h-3.1a15 15 0 00-1.3-5A8.1 8.1 0 0119.9 11zm-7.9-7a13 13 0 011.9 7h-3.8a13 13 0 011.9-7zm-3.5.9a15 15 0 00-1.3 5H4.1a8.1 8.1 0 014.4-5.1zM4.1 13h3.1a15 15 0 001.3 5A8.1 8.1 0 014.1 13zm7.9 7a13 13 0 01-1.9-7h3.8a13 13 0 01-1.9 7zm3.5-.9a15 15 0 001.3-5h3.1a8.1 8.1 0 01-4.4 5.1z"
							></path>
						</svg>
					</a>
				</p>
			</section>
			<section>
				<nav class="group-tabs" aria-label="Blog groups">
					{
						postGroups.map((group) => (
							<button
								type="button"
								class="group-tab"
								data-post-filter={group.key}
								aria-pressed={group.key === defaultGroup ? 'true' : 'false'}
							>
								{group.label}
							</button>
						))
					}
				</nav>
				<ul class="post-list">
					{
						postsWithReadTime.map(({ post, readTime, author, group }, index) => (
							<li
								class:list={['post-item', index === 0 && 'is-featured']}
								data-post-item
								data-post-group={group}
								hidden={defaultGroup !== 'all' && group !== defaultGroup}
							>
								<a class:list={['post-link', post.data.heroImage && 'has-image']} href={`/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<div class="post-content">
										{post.data.pinned && <p class="pinned">Pinned</p>}
										<p class="date">
											<span class="author">
												<img
													class="author-avatar"
													src={author.avatarUrl}
													alt=""
													aria-hidden="true"
													loading="lazy"
													decoding="async"
													referrerpolicy="no-referrer"
												/>
												<span>{author.name}</span>
											</span>
											<span aria-hidden="true">·</span>
											<FormattedDate date={post.data.pubDate} />
											<span aria-hidden="true">·</span>
											<span>{formatReadTime(readTime)}</span>
										</p>
										<h2 class="title">{post.data.title}</h2>
										<p class="desc">{post.data.description}</p>
										<p class="readmore">Read article</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
				<div class="load-more-wrap">
					<button type="button" class="load-more-button" data-load-more-posts>Load more posts</button>
				</div>
				<p class="empty-group" data-empty-group hidden>No posts in this group yet.</p>
			</section>
		</main>
		<Footer />
		<script>
			const validGroups = ['all', 'labs', 'release'];
			const pageSize = 8;
			const filterButtons = Array.from(document.querySelectorAll('[data-post-filter]'));
			const postItems = Array.from(document.querySelectorAll('[data-post-item]'));
			const loadMoreButton = document.querySelector('[data-load-more-posts]');
			const emptyGroup = document.querySelector('[data-empty-group]');
			const currentPostCount = document.querySelector('[data-current-post-count]');

			const isValidGroup = (value) => validGroups.includes(value);
			const initialGroup = 'all';
			const shownCountByGroup = Object.fromEntries(validGroups.map((group) => [group, pageSize]));
			let currentGroup = initialGroup;

			const refreshFeaturedCard = () => {
				const visible = postItems.filter((item) => !item.hidden);
				postItems.forEach((item) => item.classList.remove('is-featured'));
				visible[0]?.classList.add('is-featured');
			};

			const getGroupItems = (group) =>
				postItems.filter((item) => group === 'all' || item.dataset.postGroup === group);

			const applyGroupFilter = (group) => {
				currentGroup = group;
				const groupItems = getGroupItems(group);
				const shownCount = Math.min(shownCountByGroup[group], groupItems.length);
				postItems.forEach((item) => {
					item.hidden = true;
				});
				groupItems.forEach((item, index) => {
					item.hidden = index >= shownCount;
				});
				filterButtons.forEach((button) => {
					button.setAttribute('aria-pressed', String(button.dataset.postFilter === group));
				});
				if (currentPostCount) {
					currentPostCount.textContent = `${groupItems.length} posts`;
				}
				refreshFeaturedCard();
				if (emptyGroup) {
					emptyGroup.hidden = groupItems.length > 0;
				}
				if (loadMoreButton) {
					loadMoreButton.hidden = shownCount >= groupItems.length || groupItems.length === 0;
				}
			};

			filterButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const group = button.dataset.postFilter;
					if (isValidGroup(group)) {
						shownCountByGroup[group] = pageSize;
						applyGroupFilter(group);
					}
				});
			});

			if (loadMoreButton) {
				loadMoreButton.addEventListener('click', () => {
					shownCountByGroup[currentGroup] += pageSize;
					applyGroupFilter(currentGroup);
				});
			}

			if (isValidGroup(initialGroup)) {
				applyGroupFilter(initialGroup);
			}
		</script>
	</body>
</html>
